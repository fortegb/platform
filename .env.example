# ForteGB — environment variable template (D-044 / #165)
# Copy: cp .env.example .env
# Names: docs/planning/templates/env-vars.md (D-041)
# Scopes: docs/planning/templates/env-scoping.md (D-042)
# Access: docs/planning/templates/secrets-access.md (D-043)
# Fill real values locally / in Vercel — NEVER commit .env

# --- Runtime ---
APP_ENV=local

# --- Supabase (v1) ---
NUXT_PUBLIC_SUPABASE_URL=
NUXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Sanity (v1) ---
NUXT_PUBLIC_SANITY_PROJECT_ID=
NUXT_PUBLIC_SANITY_DATASET=
