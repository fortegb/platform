SANITY_DATASET=
SANITY_API_TOKEN=

# --- HubSpot (v1) ---
HUBSPOT_API_KEY=
HUBSPOT_WEBHOOK_SECRET=

# --- WhatsApp (v1) ---
WHATSAPP_API_KEY=
WHATSAPP_API_URL=
NUXT_PUBLIC_WHATSAPP_NUMBER=
WHATSAPP_WEBHOOK_SECRET=

# --- Telegram (v1 seam) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# --- QStash (v1) ---
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# --- Tuya (v2) ---
TUYA_ACCESS_ID=
TUYA_ACCESS_SECRET=
TUYA_WEBHOOK_SECRET=

# --- Google Calendar (v2) ---
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
