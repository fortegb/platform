#!/bin/sh
# After commits that touch docs/, refresh build-info.json in a follow-up commit.
# Hash points at the prior commit (with doc changes) — always reachable on GitHub.

ROOT="$(git rev-parse --show-toplevel)" || exit 0
cd "$ROOT" || exit 0

if [ "$PORTAL_BUILD_INFO_SKIP" = "1" ]; then
  exit 0
fi

# Avoid loop on the build-info commit itself
if git log -1 --format=%s | grep -q '^chore: refresh portal build-info$'; then
  exit 0
fi

if ! git diff-tree --no-commit-id --name-only -r HEAD | grep -q '^docs/'; then
  exit 0
fi

node scripts/update-portal-build-info.mjs || exit 0

if git diff --quiet HEAD -- docs/assets/build-info.json; then
  exit 0
fi

git add docs/assets/build-info.json
PORTAL_BUILD_INFO_SKIP=1 git commit -m "chore: refresh portal build-info" --no-verify

exit 0
